# Shared runtime
NODE_ENV=development
TRACE_API_URL=http://127.0.0.1:4000
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000

# API + database
DATABASE_URL=postgresql://terroiros:terroiros@localhost:5432/terroiros
JWT_SECRET=replace-in-production

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPERADMIN_EMAILS=

# Local-only auth bypass. Keep disabled outside isolated development.
DEV_SUPERADMIN_BYPASS=false
DEV_SUPERADMIN_BYPASS_TOKEN=dev-superadmin
NEXT_PUBLIC_DEV_SUPERADMIN_BYPASS=false

# Object storage / evidence uploads
OBJECT_STORAGE_ENDPOINT=http://127.0.0.1:9000
OBJECT_STORAGE_BUCKET=trace-evidence
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin

# Wallet + chain
CHAIN_ID=80002
CHAIN_RPC_URL=https://rpc-amoy.polygon.technology
CHAIN_RPC_FALLBACK_URL=
DEPLOYER_PRIVATE_KEY=
BATCH_REGISTRY_ADDRESS=
ATTESTATION_REGISTRY_ADDRESS=
